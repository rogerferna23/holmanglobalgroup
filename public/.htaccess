# ============================================
# HGG — Configuracion para Apache (IONOS Hosting Plus)
# ============================================
# Este archivo se copia a dist/ automaticamente cuando haces npm run build
# (Vite copia todo lo de public/ a dist/).

# ============================================
# 1) Forzar HTTPS (DEBE ir ANTES del SPA fallback)
#    NUNCA redirige /.well-known/ para que Let's Encrypt pueda validar.
# ============================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteCond %{REQUEST_URI} !^/\.well-known/
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ============================================
# 2) SPA fallback (rewrite a index.html)
# ============================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # No reescribir si el archivo o directorio existe
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # No reescribir assets/, robots.txt, sitemap.xml, favicon.ico, logos
  RewriteRule ^(assets/|robots\.txt|sitemap\.xml|favicon\.ico|icon\.png|logo) - [L]

  # Todo lo demas -> index.html (React Router maneja)
  RewriteRule ^ /index.html [L]
</IfModule>

# ============================================
# 3) Security headers
# ============================================
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self https://js.stripe.com)"

  # CSP estricta: SIN unsafe-inline en script-src (Vite buildea sin inline scripts).
  # style-src mantiene unsafe-inline porque React inyecta estilos dinamicos.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://js.stripe.com https://*.stripe.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https://*.stripe.com https://*.stripe.network; connect-src 'self' https://*.supabase.co https://api.stripe.com https://*.stripe.com; frame-src https://js.stripe.com https://*.stripe.com https://hooks.stripe.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none';"
</IfModule>

# ============================================
# 4) Compresion gzip
# ============================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/json application/javascript application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============================================
# 5) Cache para assets estaticos (hashed)
# ============================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ============================================
# 6) Bloquear acceso a archivos sensibles
# ============================================
<FilesMatch "(^\.|package(-lock)?\.json|tsconfig\.json|vite\.config\.ts|README\.md|CLAUDE\.md)">
  Order allow,deny
  Deny from all
</FilesMatch>
