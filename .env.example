# ============================================
# PayPal (Smart Buttons + Tarjeta crédito/débito)
# https://developer.paypal.com/dashboard/applications
# ============================================
# Client ID del REST API (App). Sandbox o Live según PAYPAL_ENV.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "sandbox" para pruebas, "live" para producción.
PAYPAL_ENV=sandbox
# Moneda en la que cobras (USD, EUR, GBP, MXN, etc.).
NEXT_PUBLIC_PAYMENT_CURRENCY=USD

# ============================================
# Wise — el cliente elige cómo quiere pagar
# Deja vacías las que NO uses (la opción no aparecerá).
# ============================================
# 1) Wise Payment Link (https://wise.com/pay/me/...)
NEXT_PUBLIC_WISE_PAYMENT_LINK=

# 2) Transferencia bancaria — datos de tu cuenta Wise
NEXT_PUBLIC_WISE_HOLDER=
NEXT_PUBLIC_WISE_IBAN=
NEXT_PUBLIC_WISE_SWIFT=
NEXT_PUBLIC_WISE_BANK=
# Prefijo opcional para la referencia (ej: "HGG-" → HGG-1234)
NEXT_PUBLIC_WISE_REFERENCE_PREFIX=HGG

# ============================================
# Notificación de pagos (opcional, futuro)
# ============================================
# Email donde recibirás avisos cuando se confirme un pago
PAYMENT_NOTIFY_EMAIL=
