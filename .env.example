# ============================================
# Supabase (Auth + DB + Edge Functions)
# Dashboard: https://app.supabase.com
# ============================================
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ============================================
# Stripe (cliente)
# Solo la publishable key va en el cliente. La secret y webhook secret
# se configuran en Supabase Edge Functions, NO aqui.
# https://dashboard.stripe.com/apikeys
# ============================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_o_pk_test_...

# Moneda y prefijo de referencia (opcionales)
VITE_PAYMENT_CURRENCY=USD
VITE_REFERENCE_PREFIX=HGG

# ============================================
# Edge Functions (Supabase Dashboard -> Project Settings -> Edge Functions)
# NO van en este archivo. Solo referencia:
# ============================================
# STRIPE_SECRET_KEY         = sk_live_... o sk_test_...
# STRIPE_WEBHOOK_SECRET     = whsec_...
# PRODUCTS_JSON             = [{"id":"...","title":"...","basePrice":...}]
# ALLOWED_ORIGINS           = https://holmanglobalgroup.com,https://www.holmanglobalgroup.com
# TIMEZONE                  = America/Bogota

# ============================================
# Demo de Sofía — funcion serverless /api/web-chat (Vercel)
# Estas NO llevan prefijo VITE_ (son del SERVIDOR, nunca llegan al navegador).
# Se configuran en: Vercel -> Settings -> Environment Variables.
# Para probar en local con `vercel dev`, ponlas tambien en un archivo .env.
# ============================================
OPENAI_API_KEY=sk-...            # obligatoria — tu clave de OpenAI
MODEL_CHAT=gpt-5.4-mini          # opcional — modelo (el mismo de tu Sofia-IA)
